      "Bash(docker compose:*)",
      "Bash(curl -s http://localhost:8086/ping)",
      "Bash(curl -sv http://localhost:8086/ping)",
      "Bash(curl -s http://localhost:8086/health)",
      "Bash(curl -s \"http://localhost:8086/api/v2/setup\")",
      "Bash(curl -s -H \"Authorization: Token admin\" \"http://localhost:8086/api/v2/orgs\")"
    ]
  }
}
